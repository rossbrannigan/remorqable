# Copy this file to .env.local and fill in your values
# .env.local is git-ignored and safe to store secrets

# YouTube Data API v3 key — get one at https://console.cloud.google.com
YT_API_KEY=your_youtube_api_key_here

# Base URL used by server components to call internal API routes
# Local dev: http://localhost:3000
# Production (Vercel): https://remorqable.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
